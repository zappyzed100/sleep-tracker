<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- 画面OFF中もSyncServiceが常駐してDrive同期を継続するために必要
         （詳細はSyncService.kt参照）。 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 特別なアクセス権限。ユーザーが設定画面から手動で許可する必要がある
         （UsageReporter.requestUsageAccess()がその設定画面へ誘導する）。
         画面ON区間(SCREEN_INTERACTIVE/SCREEN_NON_INTERACTIVE)の取得もUsageEvents経由
         のため、引き続き必要。 -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:hasCode="true"
        android:usesCleartextTraffic="false">
        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:exported="true">
            <meta-data android:name="android.app.lib_name" android:value="sleep_tracker" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 画面OFF・非フォアグラウンド中もWi-Fi同期を継続するための常駐サービス。
             android_bg.rsの5分タイマー（slint::Timer）はアプリがフォアグラウンドの
             間しか動かないため、その代わりにこのサービスが5分ごとにネイティブ同期を
             キックする（SyncService.kt参照）。 -->
        <service
            android:name=".SyncService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />
    </application>
</manifest>
