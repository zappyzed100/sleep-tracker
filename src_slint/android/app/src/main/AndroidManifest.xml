<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- 特別なアクセス権限。ユーザーが設定画面から手動で許可する必要がある
         （UsageReporter.requestUsageAccess()がその設定画面へ誘導する）。 -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Android 11+のパッケージ可視性制限対策。これが無いと
         PackageManager.getApplicationInfo/getApplicationLabelが自分と暗黙的に
         やり取りしたアプリ（例: com.android.settings）以外のほぼ全ての他アプリで
         例外を投げ、UsageReporter.resolveAppLabelがnullを返してしまう
         （＝実際に使っているブラウザや読書アプリ等の使用区間が「アプリに紐づかない」
         として丸ごとスキップされ、睡眠判定の在宅解除がほぼ機能しなくなる）。
         ランチャーアイコンを持つ通常の全アプリを見えるようにする標準パターン。 -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:hasCode="true"
        android:usesCleartextTraffic="false">
        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:exported="true">
            <meta-data android:name="android.app.lib_name" android:value="sleep_tracker" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
