// main.slint — アプリのルートウィンドウ
//
// 役割 : ホーム画面（睡眠予測カード・統計ストリップ）を表示する。
//        Catppuccin Mocha風の配色。Tauri版 App.css の配色変数を踏襲。

import { LineEdit } from "std-widgets.slint";

// 標準SpinBoxは常に上下ボタンが横に並んで表示され幅を取るため、
// ホバー時だけ縦積みの上下ボタンを右側に出す自作の数値スピナー。
// 自作FocusScope+キーバッファ方式は実機でキー入力が反応しない不具合があったため、
// Slint標準のTextInput（LineEditの内部実装と同じ、フォーカス・キー入力を自前で
// 面倒見てくれる低レベル部品）に置き換えた。input-type:numberで数字以外の入力は
// Slint側で自動的に弾かれる。
component NumSpin {
    in property <int> value;
    in property <int> minimum: 0;
    in property <int> maximum: 99;
    in property <bool> zero-pad: false;
    in property <length> spin-width: 60px;
    callback edited(int);

    width: root.spin-width;
    height: 34px;

    function commit(v: int) {
        root.edited(max(min(v, root.maximum), root.minimum));
    }

    ta := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { ti.focus(); }

        Rectangle {
            background: #313244;
            border-radius: 6px;
            border-width: 1px;
            border-color: ti.has-focus ? #89b4fa : (ta.has-hover ? #45475a : transparent);

            ti := TextInput {
                x: 0px;
                width: 100%;
                height: 100%;
                text: (root.zero-pad && root.value < 10) ? "0\{root.value}" : "\{root.value}";
                color: #cdd6f4;
                font-size: 15px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                single-line: true;
                input-type: number;

                key-pressed(event) => {
                    if (event.text == Key.UpArrow) {
                        root.commit(root.value + 1);
                        accept
                    } else if (event.text == Key.DownArrow) {
                        root.commit(root.value - 1);
                        accept
                    } else {
                        reject
                    }
                }
                accepted => {
                    if (self.text != "") {
                        root.commit(self.text.to-float());
                    }
                }
            }

            if ta.has-hover: Rectangle {
                x: parent.width - 20px;
                width: 20px;
                height: 100%;

                upTa := TouchArea {
                    y: 0px;
                    height: parent.height / 2;
                    width: 100%;
                    clicked => { root.commit(root.value + 1); }
                    Rectangle {
                        background: upTa.has-hover ? #45475a : transparent;
                        Text { text: "▲"; font-size: 8px; color: #a6adc8; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
                downTa := TouchArea {
                    y: parent.height / 2;
                    height: parent.height / 2;
                    width: 100%;
                    clicked => { root.commit(root.value - 1); }
                    Rectangle {
                        background: downTa.has-hover ? #45475a : transparent;
                        Text { text: "▼"; font-size: 8px; color: #a6adc8; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }
    }
}

export struct BackupEntryVM {
    path: string,
    label: string,
}

export struct SessionVM {
    start: string,
    end: string,
    time-range: string,     // "7/1 23:00 → 7/2 07:00"
    duration-label: string,
    deleting: bool,
    overlaps: bool,          // 他のセッションと時間帯が重複している
}

component DayDetailModal {
    in property <string> date-label;
    in property <string> total-label;
    in property <[SessionVM]> sessions;
    in property <bool> add-open;
    in-out property <int> add-start-y: 2026;
    in-out property <int> add-start-mo: 1;
    in-out property <int> add-start-d: 1;
    in-out property <int> add-start-h: 23;
    in-out property <int> add-start-m: 0;
    in-out property <int> add-end-y: 2026;
    in-out property <int> add-end-mo: 1;
    in-out property <int> add-end-d: 2;
    in-out property <int> add-end-h: 7;
    in-out property <int> add-end-m: 0;
    in property <string> error-text: "";
    in property <bool> excluded: false;
    in property <string> excluded-message: "";

    callback close();
    callback delete-session(string, string);
    callback toggle-add();
    callback add-session();
    callback toggle-excluded();

    backdrop := TouchArea {
        clicked => { root.close(); }
        Rectangle { background: rgba(0, 0, 0, 0.55); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 480px;
        height: 560px;
        background: #1e1e2e;
        border-radius: 12px;
        border-width: 1px;
        border-color: #313244;

        cardBlock := TouchArea {
            width: 100%;
            height: 100%;
            // カード内クリックで閉じないようにイベントを吸収する
        }

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                TextInput {
                    text: "🌙 " + root.date-label + " の睡眠";
                    color: #f9e2af;
                    font-size: 17px;
                    font-weight: 700;
                    read-only: true;
                    single-line: true;
                    horizontal-stretch: 1;
                }
                closeBtn := TouchArea {
                    width: 28px;
                    height: 28px;
                    clicked => { root.close(); }
                    Rectangle {
                        background: closeBtn.has-hover ? #313244 : transparent;
                        border-radius: 6px;
                        Text { text: "×"; color: closeBtn.has-hover ? #cdd6f4 : #a6adc8; font-size: 22px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }

            excludeBtn := TouchArea {
                height: 32px;
                clicked => { root.toggle-excluded(); }
                Rectangle {
                    background: root.excluded ? rgba(108, 112, 134, 0.35) : (excludeBtn.has-hover ? #313244 : transparent);
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: root.excluded ? #6c7086 : #45475a;
                    Text {
                        text: root.excluded ? "対象外 ✓（タップで計測対象に戻す）" : "この日を計測対象外にする（平均・予測から除外）";
                        color: root.excluded ? #cdd6f4 : #a6adc8;
                        font-size: 13px;
                        font-weight: root.excluded ? 700 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
            if root.excluded-message != "": Text {
                width: 100%;
                text: root.excluded-message;
                color: #a6e3a1;
                font-size: 12px;
                horizontal-alignment: left;
            }

            Flickable {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 8px;

                    if root.sessions.length > 0: TextInput {
                        width: 100%;
                        text: "合計 " + root.total-label;
                        color: #89b4fa;
                        font-size: 15px;
                        font-weight: 700;
                        height: 20px;
                        vertical-stretch: 0;
                        horizontal-alignment: left;
                        read-only: true;
                        single-line: true;
                    }

                    if root.sessions.length == 0: Text {
                        width: 100%;
                        text: "この日の記録なし";
                        horizontal-alignment: left;
                        color: #a6adc8;
                        font-size: 14px;
                        height: 20px;
                        vertical-stretch: 0;
                    }

                    for s in root.sessions: Rectangle {
                        vertical-stretch: 0;
                        background: s.overlaps ? rgba(243, 139, 168, 0.18) : #181825;
                        border-radius: 8px;
                        border-width: s.overlaps ? 1px : 0px;
                        border-color: #f38ba8;
                        height: 44px;
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 10px;
                            if s.overlaps: Text {
                                text: "⚠ 重複";
                                color: #f38ba8;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                            TextInput {
                                text: s.time-range;
                                color: #cdd6f4;
                                font-size: 16px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                read-only: true;
                                single-line: true;
                            }
                            TextInput {
                                text: s.duration-label;
                                color: #89b4fa;
                                font-size: 15px;
                                vertical-alignment: center;
                                read-only: true;
                                single-line: true;
                            }
                            delBtn := TouchArea {
                                width: 50px;
                                clicked => { root.delete-session(s.start, s.end); }
                                Rectangle {
                                    background: delBtn.has-hover ? #f38ba8 : rgba(243, 139, 168, 0.25);
                                    border-radius: 6px;
                                    Text {
                                        text: s.deleting ? "…" : "削除";
                                        color: delBtn.has-hover ? #1e1e2e : #f38ba8;
                                        font-size: 12px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    addToggleBtn := TouchArea {
                        height: 34px;
                        vertical-stretch: 0;
                        clicked => { root.toggle-add(); }
                        Rectangle {
                            background: addToggleBtn.has-hover ? #313244 : transparent;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #45475a;
                            Text {
                                text: root.add-open ? "▲ キャンセル" : "＋ 睡眠を手動追加";
                                color: root.add-open ? #f38ba8 : #a6e3a1;
                                font-size: 14px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    if root.add-open: VerticalLayout {
                        vertical-stretch: 0;
                        spacing: 10px;

                        Text { width: 100%; text: "🌙 入眠"; color: #f9e2af; font-size: 13px; horizontal-alignment: left; }
                        HorizontalLayout {
                            spacing: 4px;
                            NumSpin { spin-width: 66px; minimum: 2020; maximum: 2035; value: root.add-start-y; edited(v) => { root.add-start-y = v; } }
                            Text { text: "/"; color: #cdd6f4; vertical-alignment: center; }
                            NumSpin { spin-width: 50px; zero-pad: true; minimum: 1; maximum: 12; value: root.add-start-mo; edited(v) => { root.add-start-mo = v; } }
                            Text { text: "/"; color: #cdd6f4; vertical-alignment: center; }
                            NumSpin { spin-width: 50px; zero-pad: true; minimum: 1; maximum: 31; value: root.add-start-d; edited(v) => { root.add-start-d = v; } }
                            NumSpin { spin-width: 56px; zero-pad: true; minimum: 0; maximum: 23; value: root.add-start-h; edited(v) => { root.add-start-h = v; } }
                            Text { text: "時"; color: #cdd6f4; vertical-alignment: center; }
                            NumSpin { spin-width: 56px; zero-pad: true; minimum: 0; maximum: 59; value: root.add-start-m; edited(v) => { root.add-start-m = v; } }
                            Text { text: "分"; color: #cdd6f4; vertical-alignment: center; }
                        }

                        Text { width: 100%; text: "☀️ 起床"; color: #a6e3a1; font-size: 13px; horizontal-alignment: left; }
                        HorizontalLayout {
                            spacing: 4px;
                            NumSpin { spin-width: 66px; minimum: 2020; maximum: 2035; value: root.add-end-y; edited(v) => { root.add-end-y = v; } }
                            Text { text: "/"; color: #cdd6f4; vertical-alignment: center; }
                            NumSpin { spin-width: 50px; zero-pad: true; minimum: 1; maximum: 12; value: root.add-end-mo; edited(v) => { root.add-end-mo = v; } }
                            Text { text: "/"; color: #cdd6f4; vertical-alignment: center; }
                            NumSpin { spin-width: 50px; zero-pad: true; minimum: 1; maximum: 31; value: root.add-end-d; edited(v) => { root.add-end-d = v; } }
                            NumSpin { spin-width: 56px; zero-pad: true; minimum: 0; maximum: 23; value: root.add-end-h; edited(v) => { root.add-end-h = v; } }
                            Text { text: "時"; color: #cdd6f4; vertical-alignment: center; }
                            NumSpin { spin-width: 56px; zero-pad: true; minimum: 0; maximum: 59; value: root.add-end-m; edited(v) => { root.add-end-m = v; } }
                            Text { text: "分"; color: #cdd6f4; vertical-alignment: center; }
                        }

                        addBtn := TouchArea {
                            height: 36px;
                            clicked => { root.add-session(); }
                            Rectangle {
                                background: addBtn.has-hover ? #74c7ec : #89b4fa;
                                border-radius: 6px;
                                Text { text: "追加する"; color: #1e1e2e; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                    }

                    if root.error-text != "": TextInput {
                        width: 100%;
                        text: root.error-text;
                        color: #f38ba8;
                        font-size: 13px;
                        wrap: word-wrap;
                        horizontal-alignment: left;
                        vertical-stretch: 0;
                        read-only: true;
                    }
                }
            }
        }
    }
}

component BackupListModal {
    in property <[BackupEntryVM]> entries;

    callback close();
    callback restore-entry(string);
    callback restore-external();

    backdrop := TouchArea {
        clicked => { root.close(); }
        Rectangle { background: rgba(0, 0, 0, 0.55); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 420px;
        height: 480px;
        background: #1e1e2e;
        border-radius: 12px;
        border-width: 1px;
        border-color: #313244;

        cardBlock := TouchArea {
            width: 100%;
            height: 100%;
            // カード内クリックで閉じないようにイベントを吸収する
        }

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                Text {
                    text: "📦 バックアップから復元";
                    color: #f9e2af;
                    font-size: 17px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
                closeBtn := TouchArea {
                    width: 28px;
                    height: 28px;
                    clicked => { root.close(); }
                    Rectangle {
                        background: closeBtn.has-hover ? #313244 : transparent;
                        border-radius: 6px;
                        Text { text: "×"; color: closeBtn.has-hover ? #cdd6f4 : #a6adc8; font-size: 22px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }

            Text {
                width: 100%;
                text: "現在のデータは上書きされます。新しい順に表示しています。";
                color: #a6adc8;
                font-size: 12px;
                wrap: word-wrap;
            }

            Flickable {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 8px;

                    if root.entries.length == 0: Text {
                        width: 100%;
                        text: "バックアップが見つかりません";
                        color: #a6adc8;
                        font-size: 14px;
                        horizontal-alignment: left;
                    }

                    for e in root.entries: entryBtn := TouchArea {
                        vertical-stretch: 0;
                        height: 44px;
                        clicked => { root.restore-entry(e.path); }
                        Rectangle {
                            background: entryBtn.has-hover ? #313244 : #181825;
                            border-radius: 8px;
                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                Text {
                                    text: e.label;
                                    color: #cdd6f4;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }

            externalBtn := TouchArea {
                height: 36px;
                vertical-stretch: 0;
                clicked => { root.restore-external(); }
                Rectangle {
                    background: externalBtn.has-hover ? #313244 : transparent;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: #45475a;
                    Text {
                        text: "その他のファイルを選択…";
                        color: #89b4fa;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

export struct DaySummaryVM {
    date: string,          // ISO日付（クリック時にmain.rsへ渡す）
    day-label: string,     // "月\n7/1"
    duration-label: string, // "7h30m"（データなしは空文字）
    bar-frac: float,       // 0.0〜1.0（その週の最大値に対する比率）
    has-data: bool,
    active: bool,           // 選択中の日
    bedtime-y: float,       // 0.0(上端)〜1.0(下端)。入眠時刻の折れ線位置
    bedtime-has: bool,
    waketime-y: float,      // 起床時刻の折れ線位置
    waketime-has: bool,
    // まだIDLE_RESUMEが来ていない進行中の睡眠セッションがこの日にある場合の
    // 経過時間（暫定）。就寝中に一瞬起きて確認する用途で、完了済みバーとは
    // 別に、伸び続ける「進行中」バーとしてグラフ上に表示する。
    in-progress-frac: float,
    in-progress-has: bool,
    in-progress-label: string,
    // 計測対象外（平均睡眠・予測計算から除外）としてマークされた日。
    // データそのものは残すが、バーの見た目を変えて対象外だと分かるようにする。
    excluded: bool,
}

// 折れ線グラフの曲線をなめらかに描くためのサンプル点。
// Rust側でCatmull-Romスプライン補間して大量に生成し、小さい点を密に
// 並べることで実線に見せる（x/yはチャート領域内の0.0〜1.0比率）。
export struct CurvePointVM {
    x: float,
    y: float,
    new-run: bool,  // trueなら直前の点とは繋がない（データ欠損をまたぐ境界）
}

export struct CalendarDayVM {
    day: int,
    date: string,       // ISO日付
    in-month: bool,
    is-today: bool,
    in-week: bool,       // 現在選択中の週に含まれるか
}

component LegendItem {
    in property <color> swatch-color;
    in property <string> label;
    HorizontalLayout {
        height: 16px;
        spacing: 6px;
        Rectangle {
            width: 12px; height: 12px;
            y: (parent.height - self.height) / 2;
            background: root.swatch-color;
            border-radius: 2px;
        }
        Text { text: root.label; color: #cdd6f4; font-size: 12px; vertical-alignment: center; }
    }
}

// 実データのある曜日を強調する大きめの点（連続する曲線は別途CurvePointVMで描く）。
component LineDot inherits Rectangle {
    in property <float> cx;
    in property <float> cy;
    x: cx * 1px - 5px;
    y: cy * 1px - 5px;
    width: 10px;
    height: 10px;
    border-radius: 5px;
}

// 隣り合う2つのCurvePointVMを太い回転矩形で繋ぎ、点の連なりではなく
// 途切れない実線に見せる（Slintの Path はアスペクト比維持スケールで横長
// チャートに使えなかったため、細かい線分を回転させて繋ぐ方式を採る）。
// ルート要素に明示のx/y/幅/高さ0を持たせないと、内部Imageの回転原点が
// 親のレイアウト位置ぶんずれて描画される（過去にLineSegで踏んだバグ）。
component CurveSeg {
    in property <float> x1;
    in property <float> y1;
    in property <float> x2;
    in property <float> y2;
    in property <color> seg-color;
    in property <bool> connected: true;

    x: 0px;
    y: 0px;
    width: 0px;
    height: 0px;

    property <float> seg-dx: root.x2 - root.x1;
    property <float> seg-dy: root.y2 - root.y1;
    property <float> seg-len: sqrt(root.seg-dx * root.seg-dx + root.seg-dy * root.seg-dy);

    if root.connected: Rectangle {
        x: root.x1 * 1px;
        y: root.y1 * 1px - 1.5px;
        width: root.seg-len * 1px;
        height: 3px;
        background: root.seg-color;
        transform-rotation: atan2(root.seg-dy, root.seg-dx);
        transform-origin: { x: 0px, y: 1.5px };
    }
}

component WeeklyChart {
    in property <[DaySummaryVM]> week;
    in property <[string]> y-labels;
    in property <[string]> y2-labels;
    in property <[CurvePointVM]> bedtime-curve;
    in property <[CurvePointVM]> waketime-curve;
    callback day-clicked(string);
    // Android実機でのタッチ操作向け。棒グラフ上での左右スワイプで週送りする。
    callback swipe-prev();
    callback swipe-next();

    // 明示のheightは持たせない。使用箇所のvertical-stretch:1で親の余白いっぱいに
    // 伸びるようにするため（固定値があるとstretchが効かずheight:260pxのままになる）。

    property <length> axis-l: 34px;
    property <length> axis-r: 46px;
    property <length> legend-h: 24px;
    property <length> daylabel-h: 22px;
    property <length> bars-h: root.height - root.legend-h - root.daylabel-h;
    // 棒グラフの列間隔・曜日ラベルの列間隔は必ず同じ値を使う。
    // 別々の値だと列とラベルの中心がずれる（特に中間の列ほど誤差が蓄積する）。
    property <length> col-spacing: 10px;

    // ── 凡例 ──
    HorizontalLayout {
        x: root.axis-l;
        y: 0;
        width: root.width - root.axis-l - root.axis-r;
        height: root.legend-h;
        spacing: 18px;
        alignment: center;
        LegendItem { swatch-color: #f9e2af; label: "入眠"; }
        LegendItem { swatch-color: #a6e3a1; label: "起床"; }
        LegendItem { swatch-color: #89b4fa; label: "睡眠時間"; }
    }

    // ── 左Y軸ラベル・グリッド線 ──
    for lbl[i] in root.y-labels: Text {
        x: 0;
        width: root.axis-l - 6px;
        y: root.legend-h + root.bars-h * i / max(root.y-labels.length - 1, 1) - 7px;
        text: lbl;
        color: #a6adc8;
        font-size: 12px;
        horizontal-alignment: right;
    }
    for lbl[i] in root.y-labels: Rectangle {
        x: root.axis-l;
        y: root.legend-h + root.bars-h * i / max(root.y-labels.length - 1, 1);
        width: root.width - root.axis-l - root.axis-r;
        height: 1px;
        background: rgba(255, 255, 255, 0.08);
    }

    // ── 右Y軸ラベル ──
    for lbl[i] in root.y2-labels: Text {
        x: root.width - root.axis-r + 6px;
        width: root.axis-r - 6px;
        y: root.legend-h + root.bars-h * i / max(root.y2-labels.length - 1, 1) - 7px;
        text: lbl;
        color: #a6adc8;
        font-size: 12px;
        horizontal-alignment: left;
    }

    // ── 棒グラフ（Tauri版に合わせ、列幅の約55%の細さに絞る） ──
    HorizontalLayout {
        x: root.axis-l;
        y: root.legend-h;
        width: root.width - root.axis-l - root.axis-r;
        height: root.bars-h;
        spacing: root.col-spacing;
        for day[i] in root.week: col := TouchArea {
            min-width: 0px;
            preferred-width: 0px;
            horizontal-stretch: 1;
            // タップと左右スワイプを区別する。指を離した時の横方向の移動量が
            // 閾値を超えていればスワイプとして週送り、そうでなければ日付タップとして扱う。
            property <float> swipe-start-x: 0;
            property <float> swipe-dx: self.mouse-x / 1px - col.swipe-start-x;
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down) {
                    col.swipe-start-x = self.mouse-x / 1px;
                } else if (event.kind == PointerEventKind.up) {
                    if (col.swipe-dx > 60) {
                        root.swipe-prev();
                    } else if (col.swipe-dx < -60) {
                        root.swipe-next();
                    } else {
                        root.day-clicked(day.date);
                    }
                }
            }
            // 完了済みセッションが無く、進行中（暫定）のセッションだけがある日は、
            // 通常のバーの代わりに伸び続ける「進行中」バーを表示する
            // （以前は文字だけの別枠表示だったが、グラフに統合してほしいという
            // フィードバックへの対応）。
            property <bool> is-in-progress: day.in-progress-has && !day.has-data;
            property <length> bar-h: self.height * max(day.has-data ? day.bar-frac : (col.is-in-progress ? day.in-progress-frac : 0.0), 0.02);
            property <length> bar-y: self.height - self.bar-h;
            property <length> bar-w: self.width * 0.7;
            Rectangle {
                x: (parent.width - col.bar-w) / 2;
                y: col.bar-y;
                height: col.bar-h;
                width: col.bar-w;
                background: day.excluded
                    ? rgba(108, 112, 134, 0.5)
                    : (day.has-data
                        ? (day.active ? #89b4fa : rgba(137, 180, 250, 0.55))
                        : (col.is-in-progress ? rgba(249, 226, 175, 0.65) : #313244));
                border-radius: 4px;
                border-width: day.excluded ? 1px : 0px;
                border-color: #6c7086;
                animate y, height { duration: 150ms; easing: ease-out; }
            }
            if day.has-data: Text {
                y: col.bar-y + (col.bar-h - self.preferred-height) / 2;
                width: 100%;
                text: day.duration-label;
                color: day.excluded ? #a6adc8 : #11111b;
                font-size: 15px;
                font-weight: 700;
                horizontal-alignment: center;
            }
            if col.is-in-progress: Text {
                y: col.bar-y + (col.bar-h - self.preferred-height) / 2;
                width: 100%;
                text: day.in-progress-label;
                color: #11111b;
                font-size: 15px;
                font-weight: 700;
                horizontal-alignment: center;
            }
            // 計測対象外バッジ。バーの高さに関係なく常に列の一番上に固定表示する
            // （バーが低いと文字と重なって読めなくなるため）。
            if day.excluded: Text {
                y: 0px;
                width: 100%;
                text: "対象外";
                color: #6c7086;
                font-size: 14px;
                font-weight: 700;
                horizontal-alignment: center;
            }
        }
    }

    // ── 入眠・起床の折れ線（棒グラフの上に重ねる） ──
    // Rust側でCatmull-Romスプライン補間したサンプル点を小さい点で密に並べて曲線に
    // 見せる（Slintの Path はviewboxをアスペクト比維持でスケールするため横長の
    // チャートでは使えなかった）。実データのある曜日には別途大きめの点を重ねる。
    property <float> chart-w-px: (root.width - root.axis-l - root.axis-r) / 1px;
    property <float> bars-h-px: root.bars-h / 1px;
    property <float> axis-l-px: root.axis-l / 1px;
    property <float> legend-h-px: root.legend-h / 1px;

    // 棒グラフの列はcol-spacingの隙間を挟んで並ぶため、列幅は
    // 「チャート全幅からn-1個ぶんの隙間を引いてから7等分」した値になる。
    // 単純にchart-w-pxを7等分するとcol-spacingの分だけ後ろの列ほど
    // 中心がずれる（線グラフの点が棒の中心より左に寄って見えるバグの原因）。
    property <float> col-spacing-px: root.col-spacing / 1px;
    property <float> col-w-px: (root.chart-w-px - 6 * root.col-spacing-px) / 7;

    function day-cx(idx: int) -> float {
        root.axis-l-px + idx * (root.col-w-px + root.col-spacing-px) + root.col-w-px / 2
    }

    // frac は (idx + 0.5) / 7 の形の「列位置」（0.0〜1.0、連続値も取りうる）。
    // 週境界をまたぐスタブ線分（frac<0 または >1）は、Rust側のbuild_curveで
    // 既にx=0.0〜1.0にクランプ済みなので、ここでは特別な扱いは不要
    // （以前はSlintのclip:trueでクリップしていたが、Android実機のレンダリング
    // バックエンドで効かないことが判明したため、Rust側でのクランプに一本化した）。
    function curve-px-x(frac: float) -> float {
        root.axis-l-px + (frac * 7 - 0.5) * (root.col-w-px + root.col-spacing-px) + root.col-w-px / 2
    }
    function curve-px-y(frac: float) -> float {
        root.legend-h-px + frac * root.bars-h-px
    }

    for pt[i] in root.bedtime-curve: CurveSeg {
        x1: root.curve-px-x(pt.x);
        y1: root.curve-px-y(pt.y);
        x2: i + 1 < root.bedtime-curve.length ? root.curve-px-x(root.bedtime-curve[i + 1].x) : self.x1;
        y2: i + 1 < root.bedtime-curve.length ? root.curve-px-y(root.bedtime-curve[i + 1].y) : self.y1;
        connected: i + 1 < root.bedtime-curve.length && !root.bedtime-curve[i + 1].new-run;
        seg-color: #f9e2af;
    }
    for pt[i] in root.waketime-curve: CurveSeg {
        x1: root.curve-px-x(pt.x);
        y1: root.curve-px-y(pt.y);
        x2: i + 1 < root.waketime-curve.length ? root.curve-px-x(root.waketime-curve[i + 1].x) : self.x1;
        y2: i + 1 < root.waketime-curve.length ? root.curve-px-y(root.waketime-curve[i + 1].y) : self.y1;
        connected: i + 1 < root.waketime-curve.length && !root.waketime-curve[i + 1].new-run;
        seg-color: #a6e3a1;
    }
    for day[i] in root.week: LineDot {
        cx: root.day-cx(i);
        cy: root.legend-h-px + day.bedtime-y * root.bars-h-px;
        background: day.bedtime-has ? #f9e2af : transparent;
    }
    for day[i] in root.week: LineDot {
        cx: root.day-cx(i);
        cy: root.legend-h-px + day.waketime-y * root.bars-h-px;
        background: day.waketime-has ? #a6e3a1 : transparent;
    }

    // ── 昼型/夜型バッジ ──
    // 入眠（黄）が起床（緑）より上（y値が小さい）に来る日は「夜型」、
    // 逆に起床が上に来る日は「昼型」。どちらの点が上か＝どちらのy-fracが
    // 小さいかで判定する（y-fracは0.0が上端・1.0が下端、詳細はhome.rsのy_frac参照）。
    for day[i] in root.week: Text {
        x: root.day-cx(i) * 1px - 30px;
        width: 60px;
        y: (root.legend-h-px + min(day.bedtime-y, day.waketime-y) * root.bars-h-px) * 1px - 18px;
        text: day.bedtime-has && day.waketime-has ? (day.bedtime-y < day.waketime-y ? "夜型" : "昼型") : "";
        color: day.bedtime-y < day.waketime-y ? #f9e2af : #a6e3a1;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
    }

    // ── 曜日ラベル（棒グラフと同じcol-spacingで列を揃える） ──
    // TextをそのままHorizontalLayoutの子にすると、日付文字数の違い
    // （"7/2"=3文字 と "6/29"=4文字など）でTextごとのpreferred-widthが
    // 変わり、列幅が棒グラフ側（内容を持たないTouchArea＝常に均等割り）
    // とズレてバー中心とラベル中心が合わなくなる。Rectangleで包んで
    // 中身の自然幅を層のサイズ計算に影響させないようにする。
    HorizontalLayout {
        x: root.axis-l;
        y: root.legend-h + root.bars-h;
        width: root.width - root.axis-l - root.axis-r;
        height: root.daylabel-h;
        spacing: root.col-spacing;
        for day[i] in root.week: Rectangle {
            min-width: 0px;
            preferred-width: 0px;
            horizontal-stretch: 1;
            Text {
                width: 100%;
                height: 100%;
                text: day.day-label;
                color: #cdd6f4;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component CalendarPicker {
    in property <string> month-label;
    in property <[CalendarDayVM]> days;
    callback prev-month();
    callback next-month();
    callback day-clicked(string);

    // 日付セルは固定px幅で配置する。ヘッダー行とグリッド行を別々の
    // HorizontalLayoutでstretch分配すると、行ごとに端数の丸め方が変わり
    // 列がずれて見えることがあったため、単一のfor文＋固定px座標で統一する。
    property <length> cell: 34px;
    property <length> grid-w: root.cell * 7;

    width: root.grid-w + 32px;
    height: root.cell * 6 + 90px;

    Rectangle {
        background: #181825;
        border-radius: 12px;
        border-width: 2px;
        border-color: #45475a;

        cardBlock := TouchArea {
            width: 100%;
            height: 100%;
        }

        VerticalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 14px;
            padding-bottom: 14px;
            spacing: 10px;

            HorizontalLayout {
                height: 20px;
                prevM := TouchArea {
                    width: 26px;
                    clicked => { root.prev-month(); }
                    Rectangle {
                        background: prevM.has-hover ? #313244 : transparent;
                        border-radius: 4px;
                        Text { text: "◀"; color: #a6adc8; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
                TextInput {
                    text: root.month-label;
                    color: #cdd6f4;
                    font-size: 15px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    read-only: true;
                    single-line: true;
                    horizontal-stretch: 1;
                }
                nextM := TouchArea {
                    width: 26px;
                    clicked => { root.next-month(); }
                    Rectangle {
                        background: nextM.has-hover ? #313244 : transparent;
                        border-radius: 4px;
                        Text { text: "▶"; color: #a6adc8; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }

            Rectangle {
                height: 22px;
                for d[i] in ["月", "火", "水", "木", "金", "土", "日"]: Text {
                    x: root.cell * i;
                    width: root.cell;
                    y: 0;
                    height: 22px;
                    text: d;
                    color: #585b70;
                    font-size: 12px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                height: root.cell * 6;
                for day[i] in root.days: dayTa := TouchArea {
                    x: root.cell * mod(i, 7);
                    y: root.cell * floor(i / 7);
                    width: root.cell;
                    height: root.cell;
                    clicked => { root.day-clicked(day.date); }
                    Rectangle {
                        background: dayTa.has-hover ? #313244 : (day.in-week ? #313244 : transparent);
                        border-radius: 6px;
                        Text {
                            text: day.day;
                            color: day.is-today ? #89b4fa : (day.in-month ? #cdd6f4 : #585b70);
                            font-size: 13px;
                            font-weight: day.is-today ? 700 : 400;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

component StatCol {
    in property <string> value;
    in property <string> label;
    in property <color> value-color: #cdd6f4;

    VerticalLayout {
        alignment: center;
        spacing: 2px;
        TextInput {
            text: root.value;
            color: root.value-color;
            font-size: 28px;
            font-weight: 700;
            read-only: true;
            single-line: true;
        }
        Text {
            text: root.label;
            color: #a6adc8;
            font-size: 13px;
        }
    }
}

component Divider {
    width: 1px;
    height: 40px;
    Rectangle {
        width: 1px;
        height: 40px;
        background: #313244;
    }
}

component PeriodTab {
    in property <string> text;
    in property <bool> active;
    in property <length> tab-width: 58px;
    callback clicked();
    width: root.tab-width;
    height: 30px;
    horizontal-stretch: 0;
    ta := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked(); }
        Rectangle {
            background: root.active ? #89b4fa : (ta.has-hover ? #45475a : #313244);
            border-radius: 6px;
            Text {
                text: root.text;
                color: root.active ? #11111b : #a6adc8;
                font-size: 14px;
                font-weight: root.active ? 700 : 400;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component PredictionCard {
    in property <int> bed-hour;
    in property <int> bed-minute;
    in property <string> bed-time-label: "--:--";
    in property <string> predicted-duration: "—";
    in property <string> predicted-wake-time: "--:--";
    in property <string> predicted-method: "";
    // 睡眠周期（カイ二乗ペリオドグラムによる検出）。データ不足・周期不明瞭なら空文字。
    in property <string> sleep-cycle-label: "";
    in property <bool> has-data: false;
    // "now" | "optimal" | ""。今すぐ/最適睡眠は排他的な選択状態として色で示す。
    in property <string> bedtime-source: "";

    callback bedtime-edited(int, int);
    callback now-clicked();
    callback optimal-clicked();

    Rectangle {
        width: 100%;
        height: 100%;

        HorizontalLayout {
            padding-left: 20px;
        padding-right: 20px;
        spacing: 14px;
        alignment: start;

        Text {
            text: "睡眠\n予測";
            color: #a6adc8;
            font-size: 13px;
            font-weight: 700;
            vertical-alignment: center;
        }

        HorizontalLayout {
            height: 34px;
            y: (parent.height - self.height) / 2;
            spacing: 4px;
            NumSpin {
                spin-width: 60px;
                zero-pad: true;
                minimum: 0;
                maximum: 23;
                value: root.bed-hour;
                edited(v) => { root.bedtime-edited(v, root.bed-minute); }
            }
            Text { text: ":"; color: #cdd6f4; font-size: 24px; font-weight: 700; vertical-alignment: center; }
            NumSpin {
                spin-width: 60px;
                zero-pad: true;
                minimum: 0;
                maximum: 59;
                value: root.bed-minute;
                edited(v) => { root.bedtime-edited(root.bed-hour, v); }
            }
        }

        nowBtn := TouchArea {
            width: 76px;
            height: 34px;
            y: (parent.height - self.height) / 2;
            clicked => { root.now-clicked(); }
            property <bool> active: root.bedtime-source == "now";
            Rectangle {
                background: nowBtn.active ? (nowBtn.has-hover ? #74a8f7 : #89b4fa) : (nowBtn.has-hover ? #45475a : #313244);
                border-radius: 6px;
                Text {
                    text: "今すぐ";
                    color: nowBtn.active ? #11111b : #cdd6f4;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    font-size: 14px;
                    font-weight: nowBtn.active ? 700 : 400;
                }
            }
        }
        optBtn := TouchArea {
            width: 76px;
            height: 34px;
            y: (parent.height - self.height) / 2;
            clicked => { root.optimal-clicked(); }
            property <bool> active: root.bedtime-source == "optimal";
            Rectangle {
                background: optBtn.active ? (optBtn.has-hover ? #74a8f7 : #89b4fa) : (optBtn.has-hover ? #45475a : #313244);
                border-radius: 6px;
                Text {
                    text: "最適睡眠";
                    color: optBtn.active ? #11111b : #cdd6f4;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    font-size: 14px;
                    font-weight: optBtn.active ? 700 : 400;
                }
            }
        }

        if root.has-data: Divider { }

        if root.has-data: StatCol { value: root.predicted-duration; label: "予測睡眠時間"; value-color: #89b4fa; }

        if root.has-data: VerticalLayout {
            alignment: center;
            TextInput {
                text: root.bed-time-label + " 入眠 → " + root.predicted-wake-time + " 起床";
                color: #cdd6f4;
                font-size: 19px;
                font-weight: 700;
                read-only: true;
                single-line: true;
            }
        }

        if root.has-data && root.sleep-cycle-label != "": Divider { }

        if root.has-data && root.sleep-cycle-label != "": StatCol { value: root.sleep-cycle-label; label: "睡眠周期（カイ二乗ペリオドグラム）"; value-color: #f9e2af; }

        if root.has-data && root.predicted-method != "": Divider { }

        // 予測方法（Heuristic (global avg)など）は他のstrip-colと同じ
        // 「小さいラベル＋値」の左詰め形式にする。何を表しているかが
        // わかるよう「予測方法」ラベルを付ける。
        if root.has-data && root.predicted-method != "": VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text { text: "予測方法"; color: #6c7086; font-size: 11px; }
            TextInput {
                text: root.predicted-method;
                color: #a6adc8;
                font-size: 13px;
                read-only: true;
                single-line: true;
            }
        }

        if !root.has-data: Text {
            text: "データなし";
            color: #a6adc8;
            font-size: 15px;
            vertical-alignment: center;
        }
        }
    }
}

component SectionTitle {
    in property <string> text;
    width: 100%;
    Text { width: 100%; text: root.text; color: #cdd6f4; font-size: 17px; font-weight: 700; horizontal-alignment: left; }
}

component SettingsBtn {
    in property <string> text;
    in property <bool> danger: false;
    in property <bool> primary: false;
    in property <bool> busy: false;
    in property <length> btn-width: 100px;
    callback clicked();
    width: root.btn-width;
    height: 38px;
    ta := TouchArea {
        width: 100%;
        height: 100%;
        enabled: !root.busy;
        clicked => { if (!root.busy) { root.clicked(); } }
        Rectangle {
            background: root.busy
                ? #45475a
                : root.danger
                    ? (ta.has-hover ? #f38ba8 : rgba(243, 139, 168, 0.2))
                    : root.primary
                        ? (ta.pressed ? #5f95e8 : ta.has-hover ? #74c7ec : #89b4fa)
                        : (ta.pressed ? #585b70 : ta.has-hover ? #45475a : #313244);
            border-radius: 6px;
            Text {
                text: root.text;
                color: root.busy ? #a6adc8 : root.danger ? (ta.has-hover ? #1e1e2e : #f38ba8) : root.primary ? #1e1e2e : #cdd6f4;
                font-size: 15px;
                font-weight: root.primary ? 700 : 400;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component CheckRow {
    in property <bool> checked;
    in property <string> label;
    callback toggled();
    width: 100%;
    height: 30px;
    ck := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.toggled(); }
        HorizontalLayout {
            width: 100%;
            height: 100%;
            spacing: 8px;
            alignment: start;
            Rectangle {
                width: 18px; height: 18px;
                y: (parent.height - self.height) / 2;
                border-width: 1px;
                border-color: #89b4fa;
                border-radius: 4px;
                background: root.checked ? #89b4fa : transparent;
                Text { text: root.checked ? "✓" : ""; color: #1e1e2e; horizontal-alignment: center; vertical-alignment: center; }
            }
            Text {
                text: root.label;
                color: #cdd6f4;
                font-size: 16px;
                height: 18px;
                y: (parent.height - self.height) / 2;
                vertical-alignment: center;
            }
        }
    }
}

// wrap:word-wrapを使うとwidth:100%の解決前に高さが計算され、
// 「カードは少し大きくなるのに文字が見えない」不具合になっていたため、
// ステータス表示は折り返しなしの1行に変更し、高さも明示する。
// kind（"success"|"warn"|"error"|"info"）で色と太さを変え、目立たせる。
component SettingsNote {
    in property <string> text;
    in property <string> kind: "info";
    width: 100%;
    height: 22px;
    property <color> note-color: root.kind == "success" ? #a6e3a1
        : root.kind == "warn" ? #f9e2af
        : root.kind == "error" ? #f38ba8
        : #89b4fa;
    TextInput {
        width: 100%;
        height: 100%;
        text: root.text;
        color: root.note-color;
        font-size: 15px;
        font-weight: 700;
        horizontal-alignment: left;
        vertical-alignment: center;
        single-line: true;
        read-only: true;
    }
}

component SettingsSection {
    in property <string> title;
    width: 100%;
    Rectangle {
        width: 100%;
        background: #181825;
        border-radius: 12px;
        border-width: 1px;
        border-color: #313244;
        VerticalLayout {
            padding: 20px;
            spacing: 12px;
            SectionTitle { text: root.title; }
            @children
        }
    }
}

component SettingsPanel {
    in property <bool> is-mobile: false;
    in-out property <bool> startup-enabled: false;
    in-out property <int> idle-threshold-minutes: 60;
    in-out property <bool> target-wake-enabled: false;
    in-out property <int> target-wake-h: 7;
    in-out property <int> target-wake-m: 0;
    in-out property <string> mobile-url: "";
    in-out property <string> mobile-secret: "";
    in-out property <int> night-type-boundary-hour: 14;
    in-out property <int> min-screen-on-minutes: 5;
    in property <string> connection-status: "";
    in property <bool> connection-ok: false;
    in property <string> shortcut-message: "";
    in property <string> shortcut-kind: "info";
    in property <string> save-message: "";
    in property <string> save-kind: "info";
    in property <string> sync-message: "";
    in property <string> sync-kind: "info";
    in property <string> export-message: "";
    in property <string> export-kind: "info";
    in property <string> backup-message: "";
    in property <string> backup-kind: "info";
    in property <string> restore-message: "";
    in property <string> restore-kind: "info";
    in property <string> clear-message: "";
    in property <string> clear-kind: "info";
    in property <string> clear-cloud-message: "";
    in property <string> clear-cloud-kind: "info";
    in property <string> compact-message: "";
    in property <string> compact-kind: "info";
    in property <string> backups-clear-message: "";
    in property <string> backups-clear-kind: "info";
    in-out property <bool> show-secret: false;
    in property <bool> test-in-progress: false;
    in property <bool> sync-in-progress: false;
    in property <bool> export-in-progress: false;
    in property <bool> backup-in-progress: false;
    in property <bool> restore-in-progress: false;
    in property <bool> clear-in-progress: false;
    in property <bool> clear-cloud-in-progress: false;
    in property <bool> compact-in-progress: false;
    in property <bool> backups-clear-in-progress: false;
    in-out property <bool> sync-paused: false;

    callback toggle-startup(bool);
    callback toggle-sync-paused();
    callback create-shortcut();
    callback threshold-changed(int);
    callback toggle-target-wake(bool);
    callback target-wake-changed(int, int);
    callback save-settings();
    callback test-connection();
    callback sync-now();
    callback export-csv();
    callback backup();
    callback restore();
    callback clear-all-data();
    callback clear-all-data-and-cloud();
    callback compact-data();
    callback clear-backups();

    Flickable {
        VerticalLayout {
            padding: 24px;
            spacing: 20px;
            alignment: start;

            // ── 起動設定（PC自動起動・デスクトップショートカットはWindows専用の概念のため、Androidでは非表示） ──
            if !root.is-mobile: SettingsSection {
                title: "起動設定";
                CheckRow { checked: root.startup-enabled; label: "PC 起動時に自動起動する"; toggled => { root.toggle-startup(!root.startup-enabled); } }
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn { text: "デスクトップにショートカットを作成"; btn-width: 230px; clicked => { root.create-shortcut(); } }
                }
                if root.shortcut-message != "": SettingsNote { text: root.shortcut-message; kind: root.shortcut-kind; }
            }

            // ── 睡眠判定時間 ──
            SettingsSection {
                title: "睡眠判定時間";
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text { text: "キーボード / マウス操作がない状態が"; color: #cdd6f4; font-size: 16px; vertical-alignment: center; }
                    NumSpin {
                        spin-width: 74px;
                        minimum: 5; maximum: 300;
                        value: root.idle-threshold-minutes;
                        edited(v) => { root.idle-threshold-minutes = v; root.threshold-changed(v); }
                    }
                    Text { text: "分以上続いたら睡眠と判定"; color: #cdd6f4; font-size: 16px; vertical-alignment: center; }
                }
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn { text: "保存"; btn-width: 80px; primary: true; clicked => { root.save-settings(); } }
                }
                if root.save-message != "": SettingsNote { text: root.save-message; kind: root.save-kind; }
            }

            // ── 目標起床時刻 ──
            SettingsSection {
                title: "目標起床時刻";
                CheckRow { checked: root.target-wake-enabled; label: "目標起床時刻を指定する"; toggled => { root.toggle-target-wake(!root.target-wake-enabled); } }
                if root.target-wake-enabled: HorizontalLayout {
                    alignment: start;
                    spacing: 4px;
                    NumSpin { spin-width: 60px; zero-pad: true; minimum: 0; maximum: 23; value: root.target-wake-h; edited(v) => { root.target-wake-h = v; root.target-wake-changed(v, root.target-wake-m); } }
                    Text { text: ":"; color: #cdd6f4; vertical-alignment: center; }
                    NumSpin { spin-width: 60px; zero-pad: true; minimum: 0; maximum: 59; value: root.target-wake-m; edited(v) => { root.target-wake-m = v; root.target-wake-changed(root.target-wake-h, v); } }
                }
                if !root.target-wake-enabled: SettingsNote { text: "未指定の場合、過去の起床時刻の中央値を自動で使用します"; }
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn { text: "保存"; btn-width: 80px; primary: true; clicked => { root.save-settings(); } }
                }
                if root.save-message != "": SettingsNote { text: root.save-message; kind: root.save-kind; }
            }

            // ── 昼型/夜型バッジの判定基準 ──
            SettingsSection {
                title: "昼型/夜型バッジの判定基準";
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text { text: "この時刻まで寝ていたら"; color: #cdd6f4; font-size: 16px; vertical-alignment: center; }
                    NumSpin { spin-width: 60px; zero-pad: true; minimum: 0; maximum: 23; value: root.night-type-boundary-hour; edited(v) => { root.night-type-boundary-hour = v; } }
                    Text { text: "時台としてグラフ上でも夜型判定"; color: #cdd6f4; font-size: 16px; vertical-alignment: center; }
                }
                SettingsNote { text: "週間チャートの就寝/起床の折れ線と、昼型/夜型バッジの判定に使う基準時刻です（デフォルト14時）"; }
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn { text: "保存"; btn-width: 80px; primary: true; clicked => { root.save-settings(); } }
                }
                if root.save-message != "": SettingsNote { text: root.save-message; kind: root.save-kind; }
            }

            // ── タブレット画面ON区間の無視しきい値 ──
            SettingsSection {
                title: "タブレット画面ONの無視しきい値";
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text { text: "画面ONが"; color: #cdd6f4; font-size: 16px; vertical-alignment: center; }
                    NumSpin { spin-width: 74px; minimum: 0; maximum: 60; value: root.min-screen-on-minutes; edited(v) => { root.min-screen-on-minutes = v; } }
                    Text { text: "分未満なら睡眠判定では無視する"; color: #cdd6f4; font-size: 16px; vertical-alignment: center; }
                }
                SettingsNote { text: "タブレットの画面が一瞬ついただけ（通知確認等）を「起きていた」と誤判定しないための最小時間です（デフォルト5分）"; }
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn { text: "保存"; btn-width: 80px; primary: true; clicked => { root.save-settings(); } }
                }
                if root.save-message != "": SettingsNote { text: root.save-message; kind: root.save-kind; }
            }

            // ── クラウド連携 ──
            SettingsSection {
                title: "クラウド連携";
                Text { width: 100%; text: "Apps Script URL"; color: #a6adc8; font-size: 12px; font-weight: 700; horizontal-alignment: left; }
                urlEdit := LineEdit {
                    text: root.mobile-url;
                    edited(t) => { root.mobile-url = t; }
                }
                Text { width: 100%; text: "シークレット"; color: #a6adc8; font-size: 12px; font-weight: 700; horizontal-alignment: left; }
                HorizontalLayout {
                    spacing: 6px;
                    secretEdit := LineEdit {
                        text: root.mobile-secret;
                        input-type: root.show-secret ? text : password;
                        edited(t) => { root.mobile-secret = t; }
                    }
                    eyeBtn := TouchArea {
                        width: 34px;
                        height: 26px;
                        clicked => { root.show-secret = !root.show-secret; }
                        Rectangle {
                            background: eyeBtn.has-hover ? #45475a : #313244;
                            border-radius: 6px;
                            Text { text: root.show-secret ? "🙈" : "👁"; horizontal-alignment: center; vertical-alignment: center; font-size: 12px; }
                        }
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    SettingsBtn { text: "保存"; btn-width: 80px; primary: true; clicked => { root.save-settings(); } }
                    SettingsBtn {
                        text: root.test-in-progress ? "テスト中…" : "接続テスト";
                        btn-width: 100px;
                        busy: root.test-in-progress;
                        clicked => { root.test-connection(); }
                    }
                    SettingsBtn {
                        text: root.sync-in-progress ? "同期中…" : "今すぐ同期";
                        btn-width: 100px;
                        busy: root.sync-in-progress;
                        clicked => { root.sync-now(); }
                    }
                }
                if root.test-in-progress: SettingsNote { text: "接続をテストしています…"; kind: "info"; }
                if root.sync-in-progress: SettingsNote { text: "同期しています…"; kind: "info"; }
                if !root.test-in-progress && root.connection-status != "": SettingsNote { text: (root.connection-ok ? "✓ " : "✗ ") + root.connection-status; kind: root.connection-ok ? "success" : "error"; }
                if root.save-message != "": SettingsNote { text: root.save-message; kind: root.save-kind; }
                if !root.sync-in-progress && root.sync-message != "": SettingsNote { text: root.sync-message; kind: root.sync-kind; }
                SettingsNote { text: "設定は config.json にローカル保存されます"; }

                Rectangle { height: 1px; background: #313244; }

                HorizontalLayout {
                    alignment: start;
                    SettingsBtn {
                        text: root.sync-paused ? "自動同期を再開する" : "自動同期を停止する";
                        btn-width: 170px;
                        primary: root.sync-paused;
                        clicked => { root.toggle-sync-paused(); }
                    }
                }
                if root.sync-paused: SettingsNote {
                    text: "自動同期は停止中です（起動時・定期同期・睡眠検知イベントでのDrive送受信を行いません）。「今すぐ同期」ボタンは停止中でも動作します。";
                    kind: "warn";
                }
                if !root.sync-paused: SettingsNote {
                    text: "Wi-Fi/モバイルデータを切るのではなく、アプリ内の自動同期だけを止めます。";
                }
            }

            // ── データ管理 ──
            // 各ボタンの直下に、そのボタン自身の結果メッセージだけを表示する
            // （以前は4つのボタンで1つのメッセージ欄を共有しており、一番上の
            // CSVエクスポートを押しても一番下にしかメッセージが出ず分かりにくかった）。
            SettingsSection {
                title: "データ管理";
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn {
                        text: root.export-in-progress ? "書き出し中…" : "CSVエクスポート";
                        btn-width: 130px;
                        busy: root.export-in-progress;
                        clicked => { root.export-csv(); }
                    }
                }
                if root.export-message != "": SettingsNote { text: root.export-message; kind: root.export-kind; }
                SettingsNote { text: "Excel等で分析用。就寝・起床・睡眠時間・種別の4列。"; }
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn {
                        text: root.backup-in-progress ? "保存中…" : "バックアップ";
                        btn-width: 110px;
                        busy: root.backup-in-progress;
                        clicked => { root.backup(); }
                    }
                }
                if root.backup-message != "": SettingsNote { text: root.backup-message; kind: root.backup-kind; }
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn {
                        text: root.restore-in-progress ? "復元中…" : "バックアップから復元";
                        btn-width: 170px;
                        busy: root.restore-in-progress;
                        clicked => { root.restore(); }
                    }
                }
                if root.restore-message != "": SettingsNote { text: root.restore-message; kind: root.restore-kind; }
                SettingsNote { text: "生データをそのまま保存・復元。別PCへの移行や完全バックアップに。"; }
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn {
                        text: root.clear-in-progress ? "削除中…" : "ローカルの全データを削除";
                        btn-width: 190px;
                        danger: true;
                        busy: root.clear-in-progress;
                        clicked => { root.clear-all-data(); }
                    }
                }
                if root.clear-message != "": SettingsNote { text: root.clear-message; kind: root.clear-kind; }
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn {
                        text: root.clear-cloud-in-progress ? "削除中…" : "クラウドも含めて全データ削除";
                        btn-width: 220px;
                        danger: true;
                        busy: root.clear-cloud-in-progress;
                        clicked => { root.clear-all-data-and-cloud(); }
                    }
                }
                if root.clear-cloud-message != "": SettingsNote { text: root.clear-cloud-message; kind: root.clear-cloud-kind; }
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn {
                        text: root.compact-in-progress ? "圧縮中…" : "データを圧縮";
                        btn-width: 130px;
                        busy: root.compact-in-progress;
                        clicked => { root.compact-data(); }
                    }
                }
                if root.compact-message != "": SettingsNote { text: root.compact-message; kind: root.compact-kind; }
                SettingsNote { text: "パースされたセッションだけを残して再構築し、手動追加(sleep_manual.txt)は統合後に空にします。"; }
                HorizontalLayout {
                    alignment: start;
                    SettingsBtn {
                        text: root.backups-clear-in-progress ? "削除中…" : "バックアップを削除";
                        btn-width: 150px;
                        busy: root.backups-clear-in-progress;
                        clicked => { root.clear-backups(); }
                    }
                }
                if root.backups-clear-message != "": SettingsNote { text: root.backups-clear-message; kind: root.backups-clear-kind; }
                SettingsNote { text: "日次ローカル自動バックアップ(data/backups/)は自動削除されないため、ここで手動削除できます。"; }
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "睡眠トラッカー";
    icon: @image-url("../assets/icon.png");
    width: 1200px;
    height: 750px;
    background: #1e1e2e;

    in property <string> app-version: "";
    // Android実機ではステータスバー（電池残量等）とアプリ本体の描画領域が
    // 分離されておらず、トップバーがステータスバーと重なって見えてしまう
    // ため、モバイル時だけ上に余白を足す。
    in property <bool> is-mobile: false;

    // 統計ストリップ用のプロパティ（main.rsから設定される）
    in property <string> period-key: "month";
    in property <string> days-recorded: "—";
    in property <string> avg-sleep: "—";
    in property <string> last-sleep: "—";
    in property <string> wake-time: "—";
    in property <string> current-time: "—";
    in property <string> awake-since: "—";
    in property <color> awake-color: #a6e3a1;

    // 睡眠予測カード用のプロパティ
    in-out property <int> bed-hour: 22;
    in-out property <int> bed-minute: 0;
    // "now" | "optimal" | ""（手動入力など）。今すぐ/最適睡眠ボタンの
    // どちらが有効かを色で示すために使う。
    in-out property <string> bedtime-source: "";
    in property <string> bed-time-label: "--:--";
    in property <string> predicted-duration: "—";
    in property <string> predicted-wake-time: "--:--";
    in property <string> predicted-method: "";
    in property <string> sleep-cycle-label: "";
    in property <bool> has-prediction: false;

    // 週間チャート用のプロパティ
    in property <[DaySummaryVM]> week: [];
    in property <string> week-range-label: "";
    in property <[string]> y-labels: [];
    in property <[string]> y2-labels: [];
    in property <[CurvePointVM]> bedtime-curve: [];
    in property <[CurvePointVM]> waketime-curve: [];

    // カレンダーピッカー用のプロパティ
    in property <bool> cal-open: false;
    in property <string> cal-month-label: "";
    in property <[CalendarDayVM]> cal-days: [];

    // 日別詳細モーダル用のプロパティ
    in property <bool> show-detail: false;
    in property <string> detail-date-label: "";
    in property <string> detail-total-label: "";
    in property <[SessionVM]> detail-sessions: [];
    in property <bool> detail-add-open: false;
    in-out property <int> detail-add-start-y: 2026;
    in-out property <int> detail-add-start-mo: 1;
    in-out property <int> detail-add-start-d: 1;
    in-out property <int> detail-add-start-h: 23;
    in-out property <int> detail-add-start-m: 0;
    in-out property <int> detail-add-end-y: 2026;
    in-out property <int> detail-add-end-mo: 1;
    in-out property <int> detail-add-end-d: 2;
    in-out property <int> detail-add-end-h: 7;
    in-out property <int> detail-add-end-m: 0;
    in property <string> detail-error: "";
    in property <bool> detail-excluded: false;
    in property <string> detail-excluded-message: "";
    callback toggle-day-excluded();

    // バックアップ一覧モーダル用のプロパティ
    in property <bool> show-backup-list: false;
    in property <[BackupEntryVM]> backup-list: [];
    callback close-backup-list();
    callback restore-from-backup(string);
    callback restore-via-external-picker();

    // タブ切り替え
    in-out property <string> tab: "home";

    // 設定画面用のプロパティ
    in-out property <bool> startup-enabled: false;
    in-out property <int> idle-threshold-minutes: 60;
    in-out property <bool> target-wake-enabled: false;
    in-out property <int> target-wake-h: 7;
    in-out property <int> target-wake-m: 0;
    in-out property <string> mobile-url: "";
    in-out property <string> mobile-secret: "";
    in-out property <int> night-type-boundary-hour: 14;
    in-out property <int> min-screen-on-minutes: 5;
    in property <string> connection-status: "";
    in property <bool> connection-ok: false;
    in property <string> shortcut-message: "";
    in-out property <string> shortcut-kind: "info";
    in property <string> save-message: "";
    in-out property <string> save-kind: "info";
    in property <string> sync-message: "";
    in-out property <string> sync-kind: "info";
    in-out property <string> export-message: "";
    in-out property <string> export-kind: "info";
    in-out property <string> backup-message: "";
    in-out property <string> backup-kind: "info";
    in-out property <string> restore-message: "";
    in-out property <string> restore-kind: "info";
    in-out property <string> clear-message: "";
    in-out property <string> clear-kind: "info";
    in-out property <string> clear-cloud-message: "";
    in-out property <string> clear-cloud-kind: "info";
    in-out property <string> compact-message: "";
    in-out property <string> compact-kind: "info";
    in-out property <string> backups-clear-message: "";
    in-out property <string> backups-clear-kind: "info";
    in-out property <bool> test-in-progress: false;
    in-out property <bool> sync-in-progress: false;
    in-out property <bool> export-in-progress: false;
    in-out property <bool> backup-in-progress: false;
    in-out property <bool> restore-in-progress: false;
    in-out property <bool> clear-in-progress: false;
    in-out property <bool> clear-cloud-in-progress: false;
    in-out property <bool> compact-in-progress: false;
    in-out property <bool> backups-clear-in-progress: false;
    in-out property <bool> sync-paused: false;

    callback toggle-startup(bool);
    callback create-shortcut();
    callback threshold-changed(int);
    callback toggle-target-wake(bool);
    callback target-wake-changed(int, int);
    callback toggle-sync-paused();
    callback save-settings();
    callback test-connection();
    callback sync-now();
    callback export-csv();
    callback backup();
    callback restore();
    callback clear-all-data();
    callback clear-all-data-and-cloud();
    callback compact-data();
    callback clear-backups();

    callback period-changed(string);
    callback bedtime-edited(int, int);
    callback set-bedtime-now();
    callback set-bedtime-optimal();
    callback day-clicked(string);
    callback prev-week();
    callback next-week();
    callback this-week();
    callback open-calendar();
    callback close-calendar();
    callback cal-prev-month();
    callback cal-next-month();
    callback cal-day-clicked(string);
    callback close-detail();
    callback delete-session(string, string);
    callback toggle-add-session();
    callback add-session();

    // Android実機のOS標準の戻るボタン（Key.Backにマップされる）で、設定タブに
    // いる時だけホームタブへ戻る。NumSpin等の内側のFocusScopeがBackキーを
    // 処理しない（reject）場合はここまでイベントが伝播してくる。
    backFs := FocusScope {
        init => { backFs.focus(); }
        key-pressed(event) => {
            if (event.text == Key.Back && root.tab == "settings") {
                root.tab = "home";
                accept
            } else {
                reject
            }
        }

    VerticalLayout {
        spacing: 0;

        // ── ステータスバー避けの余白（Androidのみ） ──
        if root.is-mobile: Rectangle { background: #11111b; height: 32px; }

        // ── トップバー（エッジツーエッジ、Tauri版のcrust色） ──
        Rectangle {
            background: #11111b;
            height: 56px;
            HorizontalLayout {
                height: 56px;
                padding-left: 20px;
                padding-right: 20px;
                spacing: 12px;
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "睡眠トラッカー";
                        color: #cdd6f4;
                        font-size: 22px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    TextInput {
                        text: root.app-version;
                        color: #a6adc8;
                        font-size: 13px;
                        vertical-alignment: center;
                        read-only: true;
                        single-line: true;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                HorizontalLayout {
                    spacing: 4px;
                    homeTabBtn := TouchArea {
                        width: 68px;
                        height: 41px;
                        y: parent.height - self.height;
                        clicked => { root.tab = "home"; }
                        VerticalLayout {
                            alignment: end;
                            spacing: 4px;
                            Text {
                                text: "ホーム";
                                color: root.tab == "home" ? #89b4fa : #cdd6f4;
                                horizontal-alignment: center;
                                font-size: 16px;
                                font-weight: root.tab == "home" ? 700 : 400;
                            }
                            Rectangle { height: 3px; background: root.tab == "home" ? #89b4fa : transparent; }
                        }
                    }
                    settingsTabBtn := TouchArea {
                        width: 68px;
                        height: 41px;
                        y: parent.height - self.height;
                        clicked => { root.tab = "settings"; }
                        VerticalLayout {
                            alignment: end;
                            spacing: 4px;
                            Text {
                                text: "設定";
                                color: root.tab == "settings" ? #89b4fa : #cdd6f4;
                                horizontal-alignment: center;
                                font-size: 16px;
                                font-weight: root.tab == "settings" ? 700 : 400;
                            }
                            Rectangle { height: 3px; background: root.tab == "settings" ? #89b4fa : transparent; }
                        }
                    }
                }
                syncBtn := TouchArea {
                    width: 36px;
                    height: 36px;
                    y: parent.height - self.height - 3px;
                    clicked => {
                        if (!root.sync-in-progress) {
                            root.sync-in-progress = true;
                            root.sync-now();
                        }
                    }
                    property <angle> spin-angle: 0deg;
                    // 同期中は回転させ続けて「動いている」ことを一目で分かるようにする
                    // （色だけの変化は気付きにくいというフィードバックへの対応）。
                    // 減算方向（反時計回り）にしているのは、🔄の2本の矢印が時計回りの
                    // 流れを表しているため、逆方向に回すと矢印の向きと動きが噛み合って見えるため。
                    Timer {
                        interval: 16ms;
                        running: root.sync-in-progress;
                        triggered() => {
                            syncBtn.spin-angle = mod(syncBtn.spin-angle / 1deg + 354, 360) * 1deg;
                        }
                    }
                    Text {
                        // transform-originの既定値は要素の中心ではなく左上角(0, 0)のため、
                        // 明示的に中心を指定しないと回転が「その場で回らず斜めに振れる」
                        // （かつwidth/heightを親いっぱいに広げていると振れ幅がボタン全体に
                        // 及んでしまう）。width/heightで箱をボタンぴったりに合わせたうえで、
                        // transform-originを箱の中心に固定する。
                        width: 100%;
                        height: 100%;
                        transform-origin: { x: self.width / 2, y: self.height / 2 };
                        text: "🔄";
                        color: root.sync-in-progress ? #89b4fa : (syncBtn.has-hover ? #cdd6f4 : #a6adc8);
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 18px;
                        transform-rotation: syncBtn.spin-angle;
                    }
                }
            }
        }
        Rectangle { height: 1px; background: #313244; }

        if root.tab == "settings": SettingsPanel {
            vertical-stretch: 1;
            is-mobile: root.is-mobile;
            startup-enabled: root.startup-enabled;
            idle-threshold-minutes: root.idle-threshold-minutes;
            target-wake-enabled: root.target-wake-enabled;
            target-wake-h: root.target-wake-h;
            target-wake-m: root.target-wake-m;
            mobile-url <=> root.mobile-url;
            mobile-secret <=> root.mobile-secret;
            night-type-boundary-hour <=> root.night-type-boundary-hour;
            min-screen-on-minutes <=> root.min-screen-on-minutes;
            connection-status: root.connection-status;
            connection-ok: root.connection-ok;
            shortcut-message: root.shortcut-message;
            shortcut-kind: root.shortcut-kind;
            save-message: root.save-message;
            save-kind: root.save-kind;
            sync-message: root.sync-message;
            sync-kind: root.sync-kind;
            export-message: root.export-message;
            export-kind: root.export-kind;
            backup-message: root.backup-message;
            backup-kind: root.backup-kind;
            restore-message: root.restore-message;
            restore-kind: root.restore-kind;
            clear-message: root.clear-message;
            clear-kind: root.clear-kind;
            clear-cloud-message: root.clear-cloud-message;
            clear-cloud-kind: root.clear-cloud-kind;
            compact-message: root.compact-message;
            compact-kind: root.compact-kind;
            backups-clear-message: root.backups-clear-message;
            backups-clear-kind: root.backups-clear-kind;
            test-in-progress: root.test-in-progress;
            sync-in-progress: root.sync-in-progress;
            export-in-progress: root.export-in-progress;
            backup-in-progress: root.backup-in-progress;
            restore-in-progress: root.restore-in-progress;
            clear-in-progress: root.clear-in-progress;
            clear-cloud-in-progress: root.clear-cloud-in-progress;
            compact-in-progress: root.compact-in-progress;
            backups-clear-in-progress: root.backups-clear-in-progress;
            sync-paused: root.sync-paused;
            toggle-sync-paused => { root.toggle-sync-paused(); }
            toggle-startup(v) => { root.startup-enabled = v; root.toggle-startup(v); }
            create-shortcut => { root.create-shortcut(); }
            threshold-changed(v) => { root.idle-threshold-minutes = v; root.threshold-changed(v); }
            toggle-target-wake(v) => { root.target-wake-enabled = v; root.toggle-target-wake(v); }
            target-wake-changed(h, m) => { root.target-wake-h = h; root.target-wake-m = m; root.target-wake-changed(h, m); }
            save-settings => { root.save-settings(); }
            test-connection => {
                if (!root.test-in-progress) {
                    root.test-in-progress = true;
                    root.test-connection();
                }
            }
            sync-now => {
                if (!root.sync-in-progress) {
                    root.sync-in-progress = true;
                    root.sync-now();
                }
            }
            export-csv => {
                if (!root.export-in-progress) {
                    root.export-in-progress = true;
                    root.export-csv();
                }
            }
            backup => {
                if (!root.backup-in-progress) {
                    root.backup-in-progress = true;
                    root.backup();
                }
            }
            restore => {
                if (!root.restore-in-progress) {
                    root.restore-in-progress = true;
                    root.restore();
                }
            }
            clear-all-data => {
                if (!root.clear-in-progress) {
                    root.clear-in-progress = true;
                    root.clear-all-data();
                }
            }
            clear-all-data-and-cloud => {
                if (!root.clear-cloud-in-progress) {
                    root.clear-cloud-in-progress = true;
                    root.clear-all-data-and-cloud();
                }
            }
            compact-data => {
                if (!root.compact-in-progress) {
                    root.compact-in-progress = true;
                    root.compact-data();
                }
            }
            clear-backups => {
                if (!root.backups-clear-in-progress) {
                    root.backups-clear-in-progress = true;
                    root.clear-backups();
                }
            }
        }

        if root.tab == "home": homeScroll := TouchArea {
            vertical-stretch: 1;
            // マウスホイールで先週/次週を切り替える。トラックパッド等は1ジェスチャーで
            // 大量のイベントが飛んでくるため、accum-yに溜めて閾値を超えたら1回だけ送る。
            property <float> scroll-accum-y: 0;
            scroll-event(event) => {
                homeScroll.scroll-accum-y += event.delta-y / 1px;
                if homeScroll.scroll-accum-y > 60 {
                    homeScroll.scroll-accum-y = 0;
                    root.prev-week();
                } else if homeScroll.scroll-accum-y < -60 {
                    homeScroll.scroll-accum-y = 0;
                    root.next-week();
                }
                accept
            }

            VerticalLayout {
            width: 100%;
            height: 100%;

            // ── 睡眠予測 ──
            Rectangle {
                background: #181825;
                height: 64px;
                PredictionCard {
                    x: 0px;
                    y: 0px;
                    width: 100%;
                    height: 100%;
                    bed-hour: root.bed-hour;
                    bed-minute: root.bed-minute;
                    bed-time-label: root.bed-time-label;
                    predicted-duration: root.predicted-duration;
                    predicted-wake-time: root.predicted-wake-time;
                    predicted-method: root.predicted-method;
                    sleep-cycle-label: root.sleep-cycle-label;
                    has-data: root.has-prediction;
                    bedtime-source: root.bedtime-source;
                    bedtime-edited(h, m) => {
                        root.bed-hour = h;
                        root.bed-minute = m;
                        root.bedtime-source = "";
                        root.bedtime-edited(h, m);
                    }
                    now-clicked => {
                        root.bedtime-source = "now";
                        root.set-bedtime-now();
                    }
                    optimal-clicked => {
                        root.bedtime-source = "optimal";
                        root.set-bedtime-optimal();
                    }
                }
            }

            Rectangle { height: 1px; background: #313244; }

            // ── 統計ストリップ ──
            Rectangle {
                background: #181825;
                height: 64px;

                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    alignment: start;
                    spacing: 18px;

                    Text { text: "統計"; color: #a6adc8; font-size: 13px; font-weight: 700; vertical-alignment: center; horizontal-stretch: 0; }

                    HorizontalLayout {
                        horizontal-stretch: 0;
                        height: 30px;
                        y: (parent.height - self.height) / 2;
                        spacing: 6px;
                        PeriodTab { text: "先週"; active: root.period-key == "week"; clicked => { root.period-changed("week"); } }
                        PeriodTab { text: "先月"; active: root.period-key == "month"; clicked => { root.period-changed("month"); } }
                        PeriodTab { text: "1年"; active: root.period-key == "year"; clicked => { root.period-changed("year"); } }
                        PeriodTab { text: "全期間"; tab-width: 70px; active: root.period-key == "all"; clicked => { root.period-changed("all"); } }
                    }

                    Divider { }
                    StatCol { value: root.days-recorded; label: "記録日数"; }
                    Divider { }
                    StatCol { value: root.avg-sleep; label: "平均睡眠"; value-color: #89b4fa; }
                    Divider { }
                    StatCol { value: root.last-sleep; label: "最後の睡眠"; }
                    Divider { }
                    StatCol { value: root.current-time; label: "現在時刻"; }
                    Divider { }
                    StatCol { value: root.wake-time; label: "起床時刻"; }
                    Divider { }
                    StatCol { value: root.awake-since; label: "起きてから"; value-color: root.awake-color; }
                }
            }

            Rectangle { height: 1px; background: #313244; }

            // ── 週ナビゲーション（左端=前の週、右端=次の週、中央=日付、その右にカレンダー/今週） ──
            Rectangle {
                background: #181825;
                height: 50px;

                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    spacing: 12px;
                    prevBtn := TouchArea {
                        width: 96px;
                        height: 34px;
                        y: (parent.height - self.height) / 2;
                        clicked => { root.prev-week(); }
                        Rectangle {
                            background: prevBtn.has-hover ? #45475a : #313244;
                            border-radius: 6px;
                            Text { text: "‹ 前の週"; color: #cdd6f4; horizontal-alignment: center; vertical-alignment: center; font-size: 15px; }
                        }
                    }
                    TextInput {
                        text: root.week-range-label;
                        color: #cdd6f4;
                        font-size: 16px;
                        font-weight: 700;
                        read-only: true;
                        single-line: true;
                        horizontal-stretch: 1;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    calBtn := TouchArea {
                        width: 32px;
                        height: 32px;
                        y: (parent.height - self.height) / 2;
                        clicked => { root.open-calendar(); }
                        Text {
                            text: "📅";
                            color: calBtn.has-hover ? #cdd6f4 : #a6adc8;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 18px;
                        }
                    }
                    todayBtn := TouchArea {
                        width: 66px;
                        height: 34px;
                        y: (parent.height - self.height) / 2;
                        clicked => { root.this-week(); }
                        Rectangle {
                            background: todayBtn.has-hover ? #45475a : #313244;
                            border-radius: 6px;
                            Text { text: "今週"; color: #cdd6f4; horizontal-alignment: center; vertical-alignment: center; font-size: 15px; }
                        }
                    }
                    nextBtn := TouchArea {
                        width: 96px;
                        height: 34px;
                        y: (parent.height - self.height) / 2;
                        clicked => { root.next-week(); }
                        Rectangle {
                            background: nextBtn.has-hover ? #45475a : #313244;
                            border-radius: 6px;
                            Text { text: "次の週 ›"; color: #cdd6f4; horizontal-alignment: center; vertical-alignment: center; font-size: 15px; }
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: #313244; }

            // ── 週間チャート（背景なし・余白のみ。空いた縦幅は自動でチャートに回る） ──
            VerticalLayout {
                vertical-stretch: 1;
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 16px;
                padding-bottom: 18px;
                WeeklyChart {
                    vertical-stretch: 1;
                    week: root.week;
                    y-labels: root.y-labels;
                    y2-labels: root.y2-labels;
                    bedtime-curve: root.bedtime-curve;
                    waketime-curve: root.waketime-curve;
                    day-clicked(d) => { root.day-clicked(d); }
                    swipe-prev => { root.prev-week(); }
                    swipe-next => { root.next-week(); }
                }
            }
            }
        }
    }
    }

    if root.cal-open: TouchArea {
        x: 0; y: 0; width: 100%; height: 100%;
        clicked => { root.close-calendar(); }
    }
    if root.cal-open: CalendarPicker {
        x: 610px;
        y: 277px;
        month-label: root.cal-month-label;
        days: root.cal-days;
        prev-month => { root.cal-prev-month(); }
        next-month => { root.cal-next-month(); }
        day-clicked(d) => { root.cal-day-clicked(d); }
    }

    if root.show-detail: DayDetailModal {
        width: 100%;
        height: 100%;
        date-label: root.detail-date-label;
        total-label: root.detail-total-label;
        sessions: root.detail-sessions;
        add-open: root.detail-add-open;
        add-start-y: root.detail-add-start-y;
        add-start-mo: root.detail-add-start-mo;
        add-start-d: root.detail-add-start-d;
        add-start-h: root.detail-add-start-h;
        add-start-m: root.detail-add-start-m;
        add-end-y: root.detail-add-end-y;
        add-end-mo: root.detail-add-end-mo;
        add-end-d: root.detail-add-end-d;
        add-end-h: root.detail-add-end-h;
        add-end-m: root.detail-add-end-m;
        error-text: root.detail-error;
        excluded: root.detail-excluded;
        excluded-message: root.detail-excluded-message;
        close => { root.close-detail(); }
        delete-session(s, e) => { root.delete-session(s, e); }
        toggle-add => { root.toggle-add-session(); }
        add-session => { root.add-session(); }
        toggle-excluded => { root.toggle-day-excluded(); }
    }

    if root.show-backup-list: BackupListModal {
        width: 100%;
        height: 100%;
        entries: root.backup-list;
        close => { root.close-backup-list(); }
        restore-entry(p) => { root.restore-from-backup(p); }
        restore-external => { root.restore-via-external-picker(); }
    }
}
