// main.slint — アプリのルートウィンドウ
//
// 役割 : ホーム画面（睡眠予測カード・統計ストリップ）を表示する。
//        Catppuccin Mocha風の配色。Tauri版 App.css の配色変数を踏襲。

import { SpinBox, LineEdit } from "std-widgets.slint";

export struct SessionVM {
    start: string,
    end: string,
    time-range: string,     // "7/1 23:00 → 7/2 07:00"
    duration-label: string,
    deleting: bool,
}

component DayDetailModal {
    in property <string> date-label;
    in property <string> total-label;
    in property <[SessionVM]> sessions;
    in property <bool> add-open;
    in-out property <int> add-start-h: 23;
    in-out property <int> add-start-m: 0;
    in-out property <int> add-end-h: 7;
    in-out property <int> add-end-m: 0;
    in property <string> error-text: "";

    callback close();
    callback delete-session(string, string);
    callback toggle-add();
    callback add-session();

    backdrop := TouchArea {
        clicked => { root.close(); }
        Rectangle { background: rgba(0, 0, 0, 0.55); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 480px;
        height: 560px;
        background: #1e1e2e;
        border-radius: 12px;
        border-width: 1px;
        border-color: #313244;

        cardBlock := TouchArea {
            width: 100%;
            height: 100%;
            // カード内クリックで閉じないようにイベントを吸収する
        }

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                Text {
                    text: "🌙 " + root.date-label + " の睡眠";
                    color: #cdd6f4;
                    font-size: 17px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }
                closeBtn := TouchArea {
                    width: 28px;
                    height: 28px;
                    clicked => { root.close(); }
                    Rectangle {
                        background: closeBtn.has-hover ? #313244 : transparent;
                        border-radius: 6px;
                        Text { text: "✕"; color: #cdd6f4; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }

            Flickable {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 8px;

                    if root.sessions.length > 0: Text {
                        text: "合計 " + root.total-label;
                        color: #89b4fa;
                        font-size: 15px;
                        font-weight: 700;
                    }

                    if root.sessions.length == 0: Text {
                        text: "この日の記録なし";
                        color: #a6adc8;
                        font-size: 14px;
                    }

                    for s in root.sessions: Rectangle {
                        background: #181825;
                        border-radius: 8px;
                        height: 40px;
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 10px;
                            Text {
                                text: s.time-range;
                                color: #cdd6f4;
                                font-size: 13px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: s.duration-label;
                                color: #a6adc8;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                            delBtn := TouchArea {
                                width: 50px;
                                clicked => { root.delete-session(s.start, s.end); }
                                Rectangle {
                                    background: delBtn.has-hover ? #f38ba8 : rgba(243, 139, 168, 0.25);
                                    border-radius: 6px;
                                    Text {
                                        text: s.deleting ? "…" : "削除";
                                        color: delBtn.has-hover ? #1e1e2e : #f38ba8;
                                        font-size: 12px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    addToggleBtn := TouchArea {
                        height: 32px;
                        clicked => { root.toggle-add(); }
                        Rectangle {
                            background: addToggleBtn.has-hover ? #313244 : transparent;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #313244;
                            Text {
                                text: root.add-open ? "▲ キャンセル" : "＋ 睡眠を手動追加";
                                color: #cdd6f4;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    if root.add-open: VerticalLayout {
                        spacing: 10px;

                        Text { text: "🌙 入眠"; color: #f9e2af; font-size: 13px; }
                        HorizontalLayout {
                            spacing: 4px;
                            SpinBox { minimum: 0; maximum: 23; value: root.add-start-h; edited(v) => { root.add-start-h = v; } }
                            Text { text: "時"; color: #cdd6f4; vertical-alignment: center; }
                            SpinBox { minimum: 0; maximum: 59; value: root.add-start-m; edited(v) => { root.add-start-m = v; } }
                            Text { text: "分"; color: #cdd6f4; vertical-alignment: center; }
                        }

                        Text { text: "☀️ 起床"; color: #a6e3a1; font-size: 13px; }
                        HorizontalLayout {
                            spacing: 4px;
                            SpinBox { minimum: 0; maximum: 23; value: root.add-end-h; edited(v) => { root.add-end-h = v; } }
                            Text { text: "時"; color: #cdd6f4; vertical-alignment: center; }
                            SpinBox { minimum: 0; maximum: 59; value: root.add-end-m; edited(v) => { root.add-end-m = v; } }
                            Text { text: "分"; color: #cdd6f4; vertical-alignment: center; }
                        }

                        addBtn := TouchArea {
                            height: 36px;
                            clicked => { root.add-session(); }
                            Rectangle {
                                background: addBtn.has-hover ? #74c7ec : #89b4fa;
                                border-radius: 6px;
                                Text { text: "追加する"; color: #1e1e2e; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                    }

                    if root.error-text != "": Text {
                        text: root.error-text;
                        color: #f38ba8;
                        font-size: 13px;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}

export struct DaySummaryVM {
    date: string,          // ISO日付（クリック時にmain.rsへ渡す）
    day-label: string,     // "月\n7/1"
    duration-label: string, // "7h30m"（データなしは空文字）
    bar-frac: float,       // 0.0〜1.0（その週の最大値に対する比率）
    has-data: bool,
    active: bool,           // 選択中の日
}

component WeeklyChart {
    in property <[DaySummaryVM]> week;
    callback day-clicked(string);

    height: 260px;

    HorizontalLayout {
        spacing: 10px;
        for day[i] in root.week: VerticalLayout {
            spacing: 6px;
            Text {
                text: day.duration-label;
                color: #cdd6f4;
                font-size: 12px;
                horizontal-alignment: center;
                height: 16px;
            }
            col := TouchArea {
                clicked => { root.day-clicked(day.date); }
                Rectangle {
                    Rectangle {
                        y: parent.height * (1.0 - max(day.bar-frac, 0.02));
                        height: parent.height * max(day.bar-frac, 0.02);
                        width: 100%;
                        background: day.has-data ? (day.active ? #89b4fa : rgba(137, 180, 250, 0.45)) : #313244;
                        border-radius: 4px;
                        animate y, height { duration: 150ms; easing: ease-out; }
                    }
                }
            }
            Text {
                text: day.day-label;
                color: #cdd6f4;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }
    }
}

component StatCol {
    in property <string> value;
    in property <string> label;
    in property <color> value-color: #cdd6f4;

    VerticalLayout {
        spacing: 4px;
        Text {
            text: root.value;
            color: root.value-color;
            font-size: 26px;
            font-weight: 700;
        }
        Text {
            text: root.label;
            color: #a6adc8;
            font-size: 13px;
        }
    }
}

component Divider {
    Rectangle {
        width: 1px;
        height: 40px;
        background: #313244;
    }
}

component PredictionCard {
    in property <int> bed-hour;
    in property <int> bed-minute;
    in property <string> predicted-duration: "—";
    in property <string> predicted-wake-time: "--:--";
    in property <string> predicted-method: "";
    in property <bool> has-data: false;

    callback bedtime-edited(int, int);
    callback now-clicked();
    callback optimal-clicked();

    Rectangle {
        background: #181825;
        border-radius: 10px;
        height: 90px;

        HorizontalLayout {
            padding: 20px;
            spacing: 20px;
            alignment: start;

            Text {
                text: "睡眠\n予測";
                color: #a6adc8;
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: center;
            }

            HorizontalLayout {
                spacing: 4px;
                width: 160px;
                SpinBox {
                    minimum: 0;
                    maximum: 23;
                    value: root.bed-hour;
                    edited(v) => { root.bedtime-edited(v, root.bed-minute); }
                }
                Text { text: ":"; color: #cdd6f4; font-size: 20px; vertical-alignment: center; }
                SpinBox {
                    minimum: 0;
                    maximum: 59;
                    value: root.bed-minute;
                    edited(v) => { root.bedtime-edited(root.bed-hour, v); }
                }
            }

            nowBtn := TouchArea {
                width: 70px;
                clicked => { root.now-clicked(); }
                Rectangle {
                    background: nowBtn.has-hover ? #45475a : #313244;
                    border-radius: 6px;
                    Text { text: "今すぐ"; color: #cdd6f4; horizontal-alignment: center; vertical-alignment: center; font-size: 13px; }
                }
            }
            optBtn := TouchArea {
                width: 70px;
                clicked => { root.optimal-clicked(); }
                Rectangle {
                    background: optBtn.has-hover ? #45475a : #313244;
                    border-radius: 6px;
                    Text { text: "最適睡眠"; color: #cdd6f4; horizontal-alignment: center; vertical-alignment: center; font-size: 13px; }
                }
            }

            if root.has-data: Divider { }

            if root.has-data: StatCol { value: root.predicted-duration; label: "予測睡眠時間"; value-color: #89b4fa; }

            if root.has-data: VerticalLayout {
                alignment: center;
                Text { text: root.predicted-wake-time; color: #cdd6f4; font-size: 18px; font-weight: 700; }
                Text { text: root.predicted-method; color: #a6adc8; font-size: 11px; }
            }

            if !root.has-data: Text {
                text: "データなし";
                color: #a6adc8;
                font-size: 14px;
                vertical-alignment: center;
            }
        }
    }
}

component SectionTitle {
    in property <string> text;
    Text { text: root.text; color: #f9e2af; font-size: 14px; font-weight: 700; }
}

component SettingsBtn {
    in property <string> text;
    in property <bool> danger: false;
    callback clicked();
    ta := TouchArea {
        height: 34px;
        clicked => { root.clicked(); }
        Rectangle {
            background: root.danger
                ? (ta.has-hover ? #f38ba8 : rgba(243, 139, 168, 0.2))
                : (ta.has-hover ? #45475a : #313244);
            border-radius: 6px;
            Text {
                text: root.text;
                color: root.danger ? (ta.has-hover ? #1e1e2e : #f38ba8) : #cdd6f4;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component SettingsPanel {
    in-out property <bool> startup-enabled: false;
    in-out property <int> idle-threshold-minutes: 60;
    in-out property <bool> target-wake-enabled: false;
    in-out property <int> target-wake-h: 7;
    in-out property <int> target-wake-m: 0;
    in-out property <string> mobile-url: "";
    in-out property <string> mobile-secret: "";
    in property <string> connection-status: "";
    in property <bool> connection-ok: false;
    in property <string> settings-message: "";

    callback toggle-startup(bool);
    callback create-shortcut();
    callback threshold-changed(int);
    callback toggle-target-wake(bool);
    callback target-wake-changed(int, int);
    callback save-settings();
    callback test-connection();
    callback sync-now();
    callback export-csv();
    callback backup();
    callback restore();
    callback clear-all-data();

    Flickable {
        VerticalLayout {
            padding: 20px;
            spacing: 20px;
            alignment: start;

            // ── 起動設定 ──
            SectionTitle { text: "起動設定"; }
            HorizontalLayout {
                spacing: 12px;
                startCk := TouchArea {
                    width: 200px;
                    height: 30px;
                    clicked => { root.toggle-startup(!root.startup-enabled); }
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            width: 18px; height: 18px;
                            border-width: 1px;
                            border-color: #89b4fa;
                            border-radius: 4px;
                            background: root.startup-enabled ? #89b4fa : transparent;
                            Text { text: root.startup-enabled ? "✓" : ""; color: #1e1e2e; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Text { text: "PC起動時に自動起動"; color: #cdd6f4; font-size: 13px; vertical-alignment: center; }
                    }
                }
                SettingsBtn { text: "デスクトップショートカット作成"; clicked => { root.create-shortcut(); } }
            }

            // ── 睡眠判定時間 ──
            SectionTitle { text: "睡眠判定時間"; }
            HorizontalLayout {
                spacing: 8px;
                SpinBox {
                    width: 120px;
                    minimum: 5; maximum: 300;
                    value: root.idle-threshold-minutes;
                    edited(v) => { root.idle-threshold-minutes = v; root.threshold-changed(v); }
                }
                Text { text: "分以上操作がなければ睡眠と判定"; color: #a6adc8; font-size: 12px; vertical-alignment: center; }
            }

            // ── 目標起床時刻 ──
            SectionTitle { text: "目標起床時刻"; }
            HorizontalLayout {
                spacing: 12px;
                wakeCk := TouchArea {
                    width: 200px;
                    height: 30px;
                    clicked => { root.toggle-target-wake(!root.target-wake-enabled); }
                    HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            width: 18px; height: 18px;
                            border-width: 1px;
                            border-color: #89b4fa;
                            border-radius: 4px;
                            background: root.target-wake-enabled ? #89b4fa : transparent;
                            Text { text: root.target-wake-enabled ? "✓" : ""; color: #1e1e2e; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Text { text: "目標起床時刻を指定する"; color: #cdd6f4; font-size: 13px; vertical-alignment: center; }
                    }
                }
                if root.target-wake-enabled: HorizontalLayout {
                    spacing: 4px;
                    SpinBox { minimum: 0; maximum: 23; value: root.target-wake-h; edited(v) => { root.target-wake-h = v; root.target-wake-changed(v, root.target-wake-m); } }
                    Text { text: ":"; color: #cdd6f4; vertical-alignment: center; }
                    SpinBox { minimum: 0; maximum: 59; value: root.target-wake-m; edited(v) => { root.target-wake-m = v; root.target-wake-changed(root.target-wake-h, v); } }
                }
            }

            // ── クラウド連携 ──
            SectionTitle { text: "クラウド連携"; }
            VerticalLayout {
                spacing: 8px;
                Text { text: "Apps Script URL"; color: #a6adc8; font-size: 12px; }
                urlEdit := LineEdit {
                    text: root.mobile-url;
                    edited(t) => { root.mobile-url = t; }
                }
                Text { text: "シークレット"; color: #a6adc8; font-size: 12px; }
                secretEdit := LineEdit {
                    text: root.mobile-secret;
                    input-type: password;
                    edited(t) => { root.mobile-secret = t; }
                }
                HorizontalLayout {
                    spacing: 8px;
                    SettingsBtn { text: "保存"; clicked => { root.save-settings(); } }
                    SettingsBtn { text: "接続テスト"; clicked => { root.test-connection(); } }
                    SettingsBtn { text: "今すぐ同期"; clicked => { root.sync-now(); } }
                }
                if root.connection-status != "": Text {
                    text: root.connection-status;
                    color: root.connection-ok ? #a6e3a1 : #f38ba8;
                    font-size: 12px;
                }
            }

            // ── データ管理 ──
            SectionTitle { text: "データ管理"; }
            HorizontalLayout {
                spacing: 8px;
                SettingsBtn { text: "CSVエクスポート"; clicked => { root.export-csv(); } }
                SettingsBtn { text: "バックアップ"; clicked => { root.backup(); } }
                SettingsBtn { text: "復元"; clicked => { root.restore(); } }
                SettingsBtn { text: "全データ削除"; danger: true; clicked => { root.clear-all-data(); } }
            }

            if root.settings-message != "": Text {
                text: root.settings-message;
                color: #a6adc8;
                font-size: 12px;
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "睡眠トラッカー";
    width: 1200px;
    height: 750px;
    background: #1e1e2e;

    in property <string> greeting: "起動確認中...";

    // 統計ストリップ用のプロパティ（main.rsから設定される）
    in property <string> days-recorded: "—";
    in property <string> avg-sleep: "—";
    in property <string> last-sleep: "—";
    in property <string> current-time: "—";
    in property <string> awake-since: "—";
    in property <color> awake-color: #a6e3a1;

    // 睡眠予測カード用のプロパティ
    in-out property <int> bed-hour: 22;
    in-out property <int> bed-minute: 0;
    in property <string> predicted-duration: "—";
    in property <string> predicted-wake-time: "--:--";
    in property <string> predicted-method: "";
    in property <bool> has-prediction: false;

    // 週間チャート用のプロパティ
    in property <[DaySummaryVM]> week: [];
    in property <string> week-range-label: "";

    // 日別詳細モーダル用のプロパティ
    in property <bool> show-detail: false;
    in property <string> detail-date-label: "";
    in property <string> detail-total-label: "";
    in property <[SessionVM]> detail-sessions: [];
    in property <bool> detail-add-open: false;
    in-out property <int> detail-add-start-h: 23;
    in-out property <int> detail-add-start-m: 0;
    in-out property <int> detail-add-end-h: 7;
    in-out property <int> detail-add-end-m: 0;
    in property <string> detail-error: "";

    // タブ切り替え
    in-out property <string> tab: "home";

    // 設定画面用のプロパティ
    in-out property <bool> startup-enabled: false;
    in-out property <int> idle-threshold-minutes: 60;
    in-out property <bool> target-wake-enabled: false;
    in-out property <int> target-wake-h: 7;
    in-out property <int> target-wake-m: 0;
    in-out property <string> mobile-url: "";
    in-out property <string> mobile-secret: "";
    in property <string> connection-status: "";
    in property <bool> connection-ok: false;
    in property <string> settings-message: "";

    callback toggle-startup(bool);
    callback create-shortcut();
    callback threshold-changed(int);
    callback toggle-target-wake(bool);
    callback target-wake-changed(int, int);
    callback save-settings();
    callback test-connection();
    callback sync-now();
    callback export-csv();
    callback backup();
    callback restore();
    callback clear-all-data();

    callback sync-clicked();
    callback bedtime-edited(int, int);
    callback set-bedtime-now();
    callback set-bedtime-optimal();
    callback day-clicked(string);
    callback prev-week();
    callback next-week();
    callback this-week();
    callback close-detail();
    callback delete-session(string, string);
    callback toggle-add-session();
    callback add-session();

    VerticalLayout {
        padding: 20px;
        spacing: 16px;

        // ── トップバー ──
        HorizontalLayout {
            spacing: 12px;
            Text {
                text: "睡眠トラッカー";
                color: #cdd6f4;
                font-size: 22px;
                font-weight: 700;
            }
            homeTabBtn := TouchArea {
                width: 60px;
                clicked => { root.tab = "home"; }
                Rectangle {
                    background: root.tab == "home" ? #313244 : transparent;
                    border-radius: 6px;
                    Text { text: "ホーム"; color: #cdd6f4; horizontal-alignment: center; vertical-alignment: center; font-size: 13px; }
                }
            }
            settingsTabBtn := TouchArea {
                width: 60px;
                clicked => { root.tab = "settings"; }
                Rectangle {
                    background: root.tab == "settings" ? #313244 : transparent;
                    border-radius: 6px;
                    Text { text: "設定"; color: #cdd6f4; horizontal-alignment: center; vertical-alignment: center; font-size: 13px; }
                }
            }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: root.greeting;
                color: #a6adc8;
                font-size: 13px;
                vertical-alignment: center;
            }
            syncBtn := TouchArea {
                width: 80px;
                clicked => { root.sync-clicked(); }
                Rectangle {
                    background: syncBtn.has-hover ? #45475a : #313244;
                    border-radius: 6px;
                    Text {
                        text: "同期";
                        color: #cdd6f4;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        if root.tab == "settings": SettingsPanel {
            vertical-stretch: 1;
            startup-enabled: root.startup-enabled;
            idle-threshold-minutes: root.idle-threshold-minutes;
            target-wake-enabled: root.target-wake-enabled;
            target-wake-h: root.target-wake-h;
            target-wake-m: root.target-wake-m;
            mobile-url <=> root.mobile-url;
            mobile-secret <=> root.mobile-secret;
            connection-status: root.connection-status;
            connection-ok: root.connection-ok;
            settings-message: root.settings-message;
            toggle-startup(v) => { root.startup-enabled = v; root.toggle-startup(v); }
            create-shortcut => { root.create-shortcut(); }
            threshold-changed(v) => { root.idle-threshold-minutes = v; root.threshold-changed(v); }
            toggle-target-wake(v) => { root.target-wake-enabled = v; root.toggle-target-wake(v); }
            target-wake-changed(h, m) => { root.target-wake-h = h; root.target-wake-m = m; root.target-wake-changed(h, m); }
            save-settings => { root.save-settings(); }
            test-connection => { root.test-connection(); }
            sync-now => { root.sync-now(); }
            export-csv => { root.export-csv(); }
            backup => { root.backup(); }
            restore => { root.restore(); }
            clear-all-data => { root.clear-all-data(); }
        }

        if root.tab == "home": VerticalLayout {
            vertical-stretch: 1;
            spacing: 16px;

            PredictionCard {
                bed-hour: root.bed-hour;
                bed-minute: root.bed-minute;
                predicted-duration: root.predicted-duration;
                predicted-wake-time: root.predicted-wake-time;
                predicted-method: root.predicted-method;
                has-data: root.has-prediction;
                bedtime-edited(h, m) => {
                    root.bed-hour = h;
                    root.bed-minute = m;
                    root.bedtime-edited(h, m);
                }
                now-clicked => { root.set-bedtime-now(); }
                optimal-clicked => { root.set-bedtime-optimal(); }
            }

            // ── 統計ストリップ ──
            Rectangle {
                background: #181825;
                border-radius: 10px;
                height: 90px;

                HorizontalLayout {
                    padding: 20px;
                    spacing: 24px;
                    alignment: start;

                    StatCol { value: root.days-recorded; label: "記録日数"; }
                    Divider { }
                    StatCol { value: root.avg-sleep; label: "平均睡眠"; value-color: #89b4fa; }
                    Divider { }
                    StatCol { value: root.last-sleep; label: "最後の睡眠"; }
                    Divider { }
                    StatCol { value: root.current-time; label: "現在時刻"; }
                    Divider { }
                    StatCol { value: root.awake-since; label: "起きてから"; value-color: root.awake-color; }
                }
            }

            // ── 週ナビゲーション ──
            HorizontalLayout {
                spacing: 12px;
                height: 32px;
                prevBtn := TouchArea {
                    width: 32px;
                    clicked => { root.prev-week(); }
                    Rectangle {
                        background: prevBtn.has-hover ? #313244 : transparent;
                        border-radius: 6px;
                        Text { text: "◀"; color: #cdd6f4; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
                Text {
                    text: root.week-range-label;
                    color: #cdd6f4;
                    font-size: 14px;
                    vertical-alignment: center;
                }
                nextBtn := TouchArea {
                    width: 32px;
                    clicked => { root.next-week(); }
                    Rectangle {
                        background: nextBtn.has-hover ? #313244 : transparent;
                        border-radius: 6px;
                        Text { text: "▶"; color: #cdd6f4; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
                todayBtn := TouchArea {
                    width: 60px;
                    clicked => { root.this-week(); }
                    Rectangle {
                        background: todayBtn.has-hover ? #45475a : #313244;
                        border-radius: 6px;
                        Text { text: "今週"; color: #cdd6f4; horizontal-alignment: center; vertical-alignment: center; font-size: 13px; }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
            }

            // ── 週間チャート ──
            Rectangle {
                background: #181825;
                border-radius: 10px;
                vertical-stretch: 1;
                WeeklyChart {
                    x: 20px; y: 16px;
                    width: parent.width - 40px;
                    height: parent.height - 32px;
                    week: root.week;
                    day-clicked(d) => { root.day-clicked(d); }
                }
            }
        }
    }

    if root.show-detail: DayDetailModal {
        width: 100%;
        height: 100%;
        date-label: root.detail-date-label;
        total-label: root.detail-total-label;
        sessions: root.detail-sessions;
        add-open: root.detail-add-open;
        add-start-h: root.detail-add-start-h;
        add-start-m: root.detail-add-start-m;
        add-end-h: root.detail-add-end-h;
        add-end-m: root.detail-add-end-m;
        error-text: root.detail-error;
        close => { root.close-detail(); }
        delete-session(s, e) => { root.delete-session(s, e); }
        toggle-add => { root.toggle-add-session(); }
        add-session => { root.add-session(); }
    }
}
